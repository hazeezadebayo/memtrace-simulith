# Memtrace CI/CD Deployment Environment

# Hugging Face Settings
HF_TOKEN=your_hugging_face_token_here
HF_USERNAME=your_hf_username
HF_SPACE_NAME=memtrace

# Toggle for "deadly" javascript obfuscation (self-defending, debug protection, RC4)
EXTREME_OBFUSCATION=false

# Space Visibility (public or private)
HF_SPACE_VISIBILITY=public

# Deploy Configurations
CLEAN_DEPLOY=true
FACTORY_REBOOT=false

# Admin Accounts
# ADMIN_EMAILS=example@gmail.at,hazeezadebayo@gmail.com

# =============================================================================
# MEMTRACE ENGINE CONFIGURATION (Hugging Face / CI Deployment Overrides)
# =============================================================================
# Uncomment and set any of the following to override config.js defaults

# --- Infrastructure ---
# PORT=3106                        # Port for the API server (e.g., localhost:3106)
# DB_TYPE=offline                  # offline (SQLite) or online (cloud DB)
# ONLINE_DB_PROVIDER=alibaba       # If online: 'alibaba' (RDS), 'turso' (Remote SQLite), or 'postgres'
# DATABASE_URL=                    # Connection string for Alibaba or Postgres
# TURSO_AUTH_TOKEN=                # Auth token specifically for Turso edge databases
# TURSO_DATABASE_URL=              # Connection URL specifically for Turso edge databases
# GOOGLE_CLIENT_ID=                # Google OAuth Client ID for frontend login
# GOOGLE_CLIENT_SECRET=            # Google OAuth Client Secret (Optional backend validation)
# NODE_ENV=development             # 'development' (verbose logging) or 'production' (fast, hides errors)

# --- AI Orchestration ---
# LLM_PROVIDER=localllm            # The LLM engine: gemini, openai, openrouter, localllm, mock, qwen
# LLM_MODEL=LFM2-2.6B-Q5           # The specific model name to load (e.g. LFM2-2.6B-Q5)
# EMB_PROVIDER=xenova              # The Embedding engine: xenova (local transformers), openai, gemini, mock, qwen
# API_KEY=                         # Unified secret key sent OUTBOUND to OpenAI/Qwen/etc
# MAX_TOKENS=2048                  # Max output tokens the LLM is allowed to generate per response

# --- Prompt Budgets (Max character lengths to prevent LLM overflow) ---
# PROMPT_ENRICHMENT_CHAR_LIMIT=400 # Max chars per enrichment fact entry (tool data truncation)
# PROMPT_BACKSTORY=150             # Max chars for agent's core backstory injection
# PROMPT_FACTS=200                 # Max chars per individual memory fact
# PROMPT_FACTS_COUNT=3             # Max number of facts to retrieve per prompt
# PROMPT_BELIEFS=300               # Max chars for core belief injection
# PROMPT_LOCAL_EDGES=200           # Max chars for relationship/graph edges
# PROMPT_GLOBAL_SUMMARY=300        # Max chars for global world state
# PROMPT_ALTERNATE_REALITIES=200   # Max chars for hypothetical reality branches
# PROMPT_POST_CONTENT=300          # Max chars for generated social media posts
# PROMPT_INTERVIEW_HISTORY=600     # Max chars for recent conversation history
# PROMPT_BELIEF_POSITIONS=150      # Max chars for stance alignment definitions
# PROMPT_SUMMARY_POST_CONTENT=80   # Max chars for miniaturized summaries
# PROMPT_SUMMARY_POST_COUNT=8      # Number of posts to include in a rolling summary

# --- Simulation Limits (Hard caps on computational loops) ---
# LIMIT_COUNCIL_MIN_BRANCHES=3     # Minimum logical branches an agent must consider
# LIMIT_COUNCIL_MAX_BRANCHES=8     # Maximum logical branches allowed before truncation
# LIMIT_MESH_MIN_AGENTS=4          # Minimum agents required to form a valid network mesh
# LIMIT_MESH_MAX_AGENTS=40         # Hard cap on agent population to prevent crash
# LIMIT_TREE_MIN_DEPTH=2           # Minimum depth of conversational thought tree
# LIMIT_TREE_MAX_DEPTH=8           # Maximum depth of thought tree

# --- Simulation Constants (The logic coefficients dictating agent behavior) ---
# SIM_BRANCH_COUNT=4               # Standard number of divergent thoughts to generate
# SIM_PERSONA_COUNT=4              # Standard number of internal personas per agent
# SIM_WEIGHT_EVIDENCE=1.2          # Multiplier: How much hard evidence sways belief
# SIM_WEIGHT_RISK=1.1              # Multiplier: How much perceived risk deters action
# SIM_THRESH_SUPPORT=0.60          # Minimum confidence needed to publicly support an idea
# SIM_THRESH_PUSHBACK=0.45         # Threshold where doubt turns into public disagreement
# SIM_SCORE_EVIDENCE=2.8           # Score bump for providing sources
# SIM_DRIFT_FRAG=0.45              # When network splits into echo chambers
# SIM_DRIFT_SHARP=0.65             # When opinions polarize to extremes

# --- Hardware / Offline ---
# USE_WEBGPU=true                  # Set to true to utilize hardware GPU for local embedding/LLMs

# --- MemTrace Simulation Defaults (The orchestration parameters) ---
# MT_AGENT_COUNT=15                # Total number of agents alive in the simulation
# MT_MAX_ROUNDS=3                  # Max conversation volleys between agents
# MT_SIM_DAYS=3                    # How many "virtual days" the simulation lasts
# MT_NUM_POSTS=3                   # Daily social media output
# MT_POSTS_EXPOSED=2               # How many timeline posts an agent sees daily
# MT_INTERACTION_CYCLES=1           # Deep thought cycles per day
# MT_TARGET_INTERACTIONS=15        # Agent-to-agent DMs per cycle
# MT_MAX_REPLENISHMENTS=4          # Memory compaction limit
